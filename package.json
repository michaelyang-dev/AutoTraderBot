{
  "name": "auto-trader",
  "version": "1.0.0",
  "description": "Autonomous paper trading bot powered by Alpaca",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "client": "PORT=3000 react-scripts start",
    "dev": "concurrently \"npm run server\" \"sleep 2 && npm run client\"",
    "build": "react-scripts build",
    "start": "npm run dev"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "lucide-react": "^0.383.0",
    "nodemailer": "^8.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.0"
  },
  "proxy": "http://localhost:3001",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
