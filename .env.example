# ══════════════════════════════════════════
#  Alpaca API Credentials
#  Get yours at: https://app.alpaca.markets
#  Go to Paper Trading → API Keys → Generate
# ══════════════════════════════════════════

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Paper trading endpoint (do NOT change for paper trading)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Data endpoint
ALPACA_DATA_URL=https://data.alpaca.markets

# Server port
PORT=3001

# Financial Modeling Prep — earnings calendar
# Get a free key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# Telegram Notifications (optional)
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot on Telegram → copy your chat ID
# Leave blank to disable notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
